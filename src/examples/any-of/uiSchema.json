{
    "type": "VerticalLayout",
    "elements": [
        {
            "type": "Control",
            "scope": "#/properties/anyOf"
        },
        {
            "type": "Control",
            "scope": "#/properties/anyOf_required"
        },
        {
            "type": "Control",
            "scope": "#/properties/anyOf_with_data"
        },
        {
            "type": "Control",
            "scope": "#/properties/anyOf_readonly",
            "options": {
                "readonly": true
            }
        },
        {
            "type": "Control",
            "scope": "#/properties/anyOf_allow_empty",
            "options": {
                "allowEmpty": true
            }
        },
        {
            "type": "Control",
            "scope": "#/properties/anyOf_accordion",
            "options": {
                "accordion": true
            }
        },
        {
            "type": "Control",
            "scope": "#/properties/anyOf_branch_ui_schemas",
            "options": {
                "accordion": true,
                "anyOfUiSchemas": [
                    {
                        "type": "VerticalLayout",
                        "elements": [
                            { "type": "Control", "scope": "#/properties/street_address" },
                            { "type": "Control", "scope": "#/properties/city" }
                        ]
                    },
                    {
                        "type": "VerticalLayout",
                        "elements": [
                            { "type": "Control", "scope": "#/properties/name" },
                            { "type": "Control", "scope": "#/properties/mail" }
                        ]
                    }
                ]
            }
        }
    ]
}